{
  "name": "gnsscalc",
  "main": "worker/index.ts",
  "compatibility_date": "2026-03-10",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "services": [
    {
      "binding": "EPHEMERIS",
      "service": "gnsscalc-ephemeris"
    }
  ]
}
