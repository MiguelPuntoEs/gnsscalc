{
  "name": "gnsscalc-ephemeris",
  "main": "index.ts",
  "compatibility_date": "2026-03-10",
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "EPHEMERIS_COLLECTOR",
        "class_name": "EphemerisCollector"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["EphemerisCollector"]
    }
  ]
}
